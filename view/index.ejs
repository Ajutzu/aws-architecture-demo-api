<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Meme Image</title>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: Arial, sans-serif;
        background: #f5f7fb;
      }

      .card {
        background: white;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
      }

      img {
        max-width: min(90vw, 700px);
        height: auto;
        display: block;
        border-radius: 8px;
      }
    </style>
  </head>
  <body>
    <main class="card">
      <img src="/meme-image.jpg" alt="Meme image" />
    </main>
  </body>
</html>
